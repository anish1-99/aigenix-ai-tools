  <script>
  /*************************************************************************
   * CLIENT SCRIPT — single-file
   *
   * Behavior:
   * - UI management (tools, studio, pricing, earn)
   * - Calls Groq API via:
   *     a) Proxy: POST /api/groq  (recommended — create a serverless function that uses process.env.GROQ_API_KEY)
   *     b) Direct: use window.GROQ_API_KEY (UNSAFE — only for local testing)
   *
   * Groq API endpoint: https://api.groq.com/openai/v1/chat/completions
   * Model: mixtral-8x7b-32768
   *
   * If you need the serverless function, use the example in the top comments.
   *************************************************************************/

  // CONFIG
  const GROQ_API_URL = 'https://api.groq.com/openai/v1/chat/completions';
  const GROQ_MODEL = 'mixtral-8x7b-32768';

  // The recommended production flow: create /api/groq serverless function and do NOT put secrets on the client.
  // For local testing only (unsafe) you may set window.GROQ_API_KEY manually from browser console:
  // window.GROQ_API_KEY = 'sk-...'

  // Data (tools, prompts, plans) — simplified from your provided app
  const TOOLS = [
    {id:"writer",cat:"Text",icon:"✍️",name:"AI Writer",desc:"Blog posts & articles",cost:3,tag:"Popular"},
    {id:"caption",cat:"Text",icon:"📱",name:"Caption Generator",desc:"Instagram, YouTube, TikTok captions",cost:2,tag:""},
    {id:"email",cat:"Text",icon:"📧",name:"Email Writer",desc:"Cold emails & newsletters",cost:2,tag:""},
    {id:"resume",cat:"Text",icon:"📄",name:"Resume Builder",desc:"ATS-optimized resumes",cost:4,tag:"New"},
    {id:"imagine",cat:"Image",icon:"🎨",name:"Image Generator",desc:"AI art from text prompts",cost:5,tag:"🔥 Hot"},
    {id:"logo",cat:"Image",icon:"🏷️",name:"Logo Concept",desc:"Professional logo brief",cost:3,tag:""},
    {id:"vidscript",cat:"Video",icon:"🎬",name:"Video Script",desc:"YouTube scripts with hooks",cost:4,tag:"Popular"},
    {id:"shorts",cat:"Video",icon:"📲",name:"Shorts Script",desc:"60-second viral scripts",cost:3,tag:""},
    {id:"business",cat:"Biz",icon:"💼",name:"Business Ideas",desc:"Profitable niche ideas",cost:3,tag:""},
    {id:"hashtag",cat:"Biz",icon:"#️⃣",name:"Hashtag Strategy",desc:"30 viral hashtags",cost:1,tag:""},
  ];

  const PROMPTS = {
    writer:    q=>`Write a comprehensive, engaging article about: "${q}". Use H2 headings, intro, main sections, and a strong conclusion. Use markdown.`,
    caption:   q=>`Create 6 scroll-stopping social media captions for: "${q}". Mix tones, add emojis and CTA. Include 10 hashtags. Number each.`,
    email:     q=>`Write a compelling email for: "${q}". Include: 2 subject line options, preview text, hook, body, CTA, sign-off.`,
    resume:    q=>`Create a professional resume section for: "${q}". Include: Summary (3 lines), 10 Skills, 3 achievement bullets with metrics, Headline.`,
    imagine:   q=>`Write 3 detailed AI image generation prompts for: "${q}". Each must include subject, art style, lighting, mood, color palette, camera angle, quality tags. Number clearly.`,
    logo:      q=>`Create a logo design brief for: "${q}". Include: Brand personality, Color palette (hex), Typography, 3 Logo concepts, Icon style.`,
    vidscript: q=>`Write a complete YouTube script for: "${q}". Structure: HOOK (15s), INTRO (30s), MAIN (4-5 points), MID CTA, OUTRO (30s).`,
    shorts:    q=>`Write a 60-second Reels/Shorts script for: "${q}". Structure: 0-3s HOOK, 3-15s SETUP, 15-45s VALUE, 45-55s PAYOFF, 55-60s CTA.`,
    business:  q=>`Generate 5 profitable business ideas for: "${q}". For each: Name, Pitch, Problem, Target customer, Revenue model, 30-day launch plan.`,
    hashtag:   q=>`Create hashtag strategy for: "${q}". 30 hashtags in 3 tiers: High Volume (10), Medium (10), Niche (10). Include best posting times.`,
  };

  const PLANS = [
    {id:"m1",label:"1 Month",price:199,credits:400,popular:false,save:"",badge:"Starter"},
    {id:"m2",label:"2 Months",price:499,credits:1000,popular:true,save:"Save 20%",badge:"Best Value"},
    {id:"m3",label:"3 Months",price:699,credits:1600,popular:false,save:"Save 30%",badge:"Pro"},
    {id:"y1",label:"1 Year",price:2999,credits:9999,popular:false,save:"Save 58%",badge:"Unlimited"},
  ];

  const EARN = [
    { id:"watch", icon:"📺", label:"Watch Ad", credits:3, duration:3500 },
    { id:"daily", icon:"🗓️", label:"Daily Bonus", credits:3, duration:1200 },
    { id:"share", icon:"🔗", label:"Share App", credits:5, duration:2000 },
    { id:"refer", icon:"👥", label:"Refer Friend", credits:15, duration:2000 },
  ];

  // App state
  const state = {
    credits: 30,
    page: 'home',
    category: 'All',
    selectedTool: null,
    history: [],
    toastTimer: null,
    earnDone: {},
    earnBusy: {}
  };

  // Simple helpers
  const $ = s => document.querySelector(s);
  const $$ = s => Array.from(document.querySelectorAll(s));

  function showToast(msg, type='success'){
    clearTimeout(state.toastTimer);
    const root = $('#toastRoot');
    root.innerHTML = '';
    const el = document.createElement('div');
    el.className = 'toast ' + (type==='error' ? 'error' : 'success');
    el.textContent = (type==='error' ? '⚠ ' : '✓ ') + msg;
    root.appendChild(el);
    state.toastTimer = setTimeout(()=> root.innerHTML = '', 3000);
  }

  function setPage(page){
    state.page = page;
    $$('.navbtn').forEach(b => b.classList.toggle('active', b.dataset.page===page));
    $('#homePage').style.display = page==='home' ? 'block' : 'none';
    $('#studioPage').style.display = page==='studio' ? 'block' : 'none';
    $('#pricingPage').style.display = page==='pricing' ? 'block' : 'none';
    $('#earnPage').style.display = page==='earn' ? 'block' : 'none';
  }

  function renderTools(filter='All'){
    const grid = $('#toolsGrid');
    grid.innerHTML = '';
    const filtered = TOOLS.filter(t => filter==='All' || t.cat===filter);
    filtered.forEach(t => {
      const c = document.createElement('div');
      c.className = 'card';
      c.innerHTML = `
        <div style="font-size:24px">${t.icon}</div>
        <div style="font-weight:700;margin-top:8px">${t.name}</div>
        <div style="color:var(--muted);font-size:13px;margin-top:6px">${t.desc}</div>
        <div style="display:flex;justify-content:space-between;align-items:center;margin-top:12px">
          <div style="font-size:12px;color:#a78bfa;background:rgba(139,92,246,0.08);padding:6px;border-radius:16px">⚡ ${t.cost} credits</div>
          ${t.tag ? '<div style="font-size:12px;color:#c4b5fd;background:rgba(139,92,246,0.08);padding:6px;border-radius:12px">'+t.tag+'</div>':''}
        </div>`;
      c.addEventListener('click', ()=> openTool(t));
      grid.appendChild(c);
    });
  }

  function renderPicker(){
    const picker = $('#toolPicker');
    picker.innerHTML = '';
    TOOLS.forEach(t => {
      const btn = document.createElement('button');
      btn.className = 'tool-btn';
      btn.textContent = t.icon + ' ' + t.name;
      btn.addEventListener('click', ()=>{
        selectTool(t);
        $$('.tool-btn').forEach(x=>x.classList.toggle('active', x===btn));
      });
      picker.appendChild(btn);
    });
  }

  function selectTool(t){
    state.selectedTool = t;
    $('#toolInfo').style.display = 'block';
    $('#toolInfo').innerHTML = '<strong style="font-size:16px">'+t.icon+' '+t.name+'</strong><div class="small" style="margin-top:6px">'+t.desc+'</div>';
    $('#studioPrompt').placeholder = 'Describe what you want from ' + t.name + '...';
  }

  function updateCredits(){
    $('#credits').textContent = state.credits;
    $('#credits2').textContent = state.credits;
  }

  // Fetch wrapper: uses proxy /api/groq if window.GROQ_API_KEY not present
  async function fetchGroqAPI(promptText, opts = {}) {
    const body = {
      model: GROQ_MODEL,
      max_tokens: opts.max_tokens || 800,
      messages: [{ role: 'user', content: PROMPTS[state.selectedTool.id ? state.selectedTool.id : 'writer'](promptText) }]
    };

    // Prefer serverless proxy at /api/groq (recommended). If GROQ_API_KEY is set on window, will call directly.
    const directKey = (window.GROQ_API_KEY && typeof window.GROQ_API_KEY === 'string' && window.GROQ_API_KEY.length>0) ? window.GROQ_API_KEY : null;

    if (directKey) {
      // Direct call (unsafe in production)
      const res = await fetch(GROQ_API_URL, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': 'Bearer ' + directKey
        },
        body: JSON.stringify(body)
      });
      if (!res.ok) {
        const text = await res.text().catch(()=>res.statusText);
        throw new Error('Groq API error: ' + res.status + ' ' + text);
      }
      return res.json();
    } else {
      // Proxy mode: call your serverless endpoint that uses GROQ_API_KEY from env
      const res = await fetch('/api/groq', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
      });
      if (!res.ok) {
        const text = await res.text().catch(()=>res.statusText);
        throw new Error('Proxy error: ' + res.status + ' ' + text);
      }
      return res.json();
    }
  }

  async function generate(){
    const promptText = (document.getElementById('studioPrompt').value || '').trim();
    if (!promptText) return showToast('Enter a prompt first!', 'error');
    if (!state.selectedTool) return showToast('Select a tool first!', 'error');
    if (state.credits < state.selectedTool.cost) return showToast('Not enough credits!', 'error');

    $('#studioOutput').style.display='none';
    $('#outputBox').textContent = '';
    $('#generateBtn').textContent = '⟳ Generating...';
    $('#generateBtn').disabled = true;

    try {
      const data = await fetchGroqAPI(promptText, { max_tokens: 1200 });
      // Groq/OpenAI-compatible response commonly has choices[0].message.content
      let text = '';
      try {
        text = data.choices?.[0]?.message?.content ?? data.choices?.[0]?.text ?? JSON.stringify(data);
      } catch (e) { text = JSON.stringify(data) }
      $('#outputBox').textContent = text;
      $('#studioOutput').style.display = 'block';

      state.credits = Math.max(0, state.credits - state.selectedTool.cost);
      state.history.unshift({ id: Date.now(), icon: state.selectedTool.icon, name: state.selectedTool.name, snippet: promptText.slice(0,40) });
      if (state.history.length > 10) state.history.length = 10;
      renderHistory();
      updateCredits();
      showToast('Done! −' + state.selectedTool.cost + ' credits');
      setTimeout(()=> document.getElementById('outputBox').scrollIntoView({ behavior:'smooth' }), 120);
    } catch (err) {
      console.error(err);
      showToast(err.message || 'Network error', 'error');
    } finally {
      $('#generateBtn').textContent = '✨ Generate';
      $('#generateBtn').disabled = false;
    }
  }

  function renderHistory(){
    const list = $('#historyList');
    list.innerHTML = '';
    if (!state.history.length) { $('#historyWrap').style.display = 'none'; return; }
    $('#historyWrap').style.display = 'block';
    state.history.forEach(h => {
      const d = document.createElement('div');
      d.style.display='flex'; d.style.alignItems='center'; d.style.gap='8px'; d.style.padding='8px'; d.style.borderRadius='8px'; d.style.background='rgba(255,255,255,0.02)';
      d.innerHTML = `<div>${h.icon}</div><div style="color:#a78bfa;font-weight:600">${h.name}</div><div style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${h.snippet}...</div>`;
      list.appendChild(d);
    });
  }

  function renderPricing(){
    const grid = $('#pricingGrid');
    grid.innerHTML = '';
    // Free
    const free = document.createElement('div'); free.className = 'plan';
    free.innerHTML = '<div style="font-weight:800;color:rgba(255,255,255,0.4)">FREE</div><div style="font-size:28px;font-weight:800">₹0</div><div class="small">Forever</div><div style="margin-top:12px"><button class="btn" id="startFree">Start Free</button></div>';
    grid.appendChild(free);
    PLANS.forEach(p=>{
      const el = document.createElement('div'); el.className='plan';
      el.innerHTML = '<div style="display:flex;justify-content:space-between;align-items:center"><div style="font-weight:800">'+p.badge+'</div>'+(p.save?'<div style="font-size:12px;color:#6ee7b7">'+p.save+'</div>':'')+'</div><div style="font-size:24px;font-weight:800;margin-top:8px">₹'+p.price+'</div><div class="small" style="margin:6px 0">'+p.label+'</div><div style="margin-top:12px"><button class="btn buyplan">Buy '+p.badge+'</button></div>';
      el.querySelector('.buyplan').addEventListener('click', ()=> {
        if (!confirm('Simulate purchase of '+p.badge+' for ₹'+p.price+'?')) return;
        state.credits += p.credits;
        updateCredits();
        showToast(p.badge+' activated! +'+p.credits+' credits');
        setPage('studio');
      });
      grid.appendChild(el);
    });
    $('#startFree')?.addEventListener('click', ()=> setPage('studio'));
  }

  function renderEarn(){
    const grid = $('#earnGrid');
    grid.innerHTML = '';
    EARN.forEach(a => {
      const b = document.createElement('button');
      b.className = 'card';
      b.style.textAlign = 'left';
      b.disabled = !!state.earnDone[a.id];
      b.innerHTML = '<div style="font-size:20px">'+(state.earnBusy[a.id] ? '⏳' : (state.earnDone[a.id] ? '✅' : a.icon))+'</div><div style="font-weight:700;margin-top:8px">'+a.label+'</div><div style="font-size:13px;margin-top:8px">'+(state.earnDone[a.id] ? 'Claimed' : '+'+a.credits+' credits')+'</div>';
      b.addEventListener('click', ()=>{
        if (state.earnBusy[a.id] || state.earnDone[a.id]) return;
        state.earnBusy[a.id] = true;
        renderEarn();
        setTimeout(()=> {
          state.earnBusy[a.id] = false;
          state.earnDone[a.id] = true;
          state.credits += a.credits;
          updateCredits();
          showToast('+'+a.credits+' credits earned!');
          renderEarn();
        }, a.duration);
      });
      grid.appendChild(b);
    });
  }

  // bindings
  $$('.navbtn').forEach(b => b.addEventListener('click', ()=> setPage(b.dataset.page)));
  $('#homeBtn').addEventListener('click', ()=> setPage('home'));
  $('#toStudio').addEventListener('click', ()=> { setPage('studio'); $('#studioPrompt').value = $('#globalPrompt').value || ''; });
  $('#generateBtn').addEventListener('click', generate);
  $('#clearBtn').addEventListener('click', ()=> { $('#studioPrompt').value = ''; $('#outputBox').textContent = ''; $('#studioOutput').style.display = 'none'; });
  $('#copyBtn').addEventListener('click', ()=> {
    const t = $('#outputBox').textContent || '';
    if (!t) return showToast('Nothing to copy', 'error');
    navigator.clipboard?.writeText(t).then(()=> showToast('Copied! 📋')).catch(()=> showToast('Copy failed', 'error'));
  });
  $('#upgradeBtn').addEventListener('click', ()=> setPage('pricing'));
  $('#copyRef').addEventListener('click', ()=> navigator.clipboard?.writeText('aigenix.app/ref/user4829').then(()=>showToast('Link copied! 🔗')));

  $$('.tool-filter').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const cat = e.currentTarget.dataset.cat;
      $$('.tool-filter').forEach(x => x.style.background = 'transparent');
      e.currentTarget.style.background = 'rgba(139,92,246,0.12)';
      renderTools(cat);
    });
  });

  // init
  function init(){
    renderTools();
    renderPicker();
    renderPricing();
    renderEarn();
    selectTool(TOOLS[0]);
    updateCredits();
    setPage('home');
  }

  init();

  // daily reset of earn items at local midnight
  (function dailyReset(){
    const now = new Date();
    const midnight = new Date(now.getFullYear(), now.getMonth(), now.getDate()+1).getTime();
    setTimeout(()=> { state.earnDone={}; renderEarn(); dailyReset(); }, midnight - now.getTime() + 1000);
  })();

  // Expose quick helper for local testing (unsafe)
  window.__AIGENIX = {
    state,
    setKey: (k) => { window.GROQ_API_KEY = k; console.warn('Set GROQ_API_KEY on window (client). This is insecure in production.'); }
  };
  </script>
</body>
</html>